        "            s_day = 33\n",
        "            s_month -= 1\n",
        "        if s_month > 11:\n",
        "            s_month = 1\n",
        "            s_year += 1\n",
        "        if s_month == 0:\n",
        "            s_month = 11\n",
        "\n",
        "        season = (\n",
        "            \"Winter\"\n",
        "            if s_month <= 3\n",
