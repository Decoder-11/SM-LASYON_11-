        "\n",
        "    def find_11_pattern_intervals(self):\n",
        "        \"\"\"11'e bolunebilen veya 11'in katlari olan araliklari bul.\"\"\"\n",
        "        intervals = self._results.get('intervals', self.compute_intervals())\n",
        "\n",
        "        pattern_hits = []\n",
