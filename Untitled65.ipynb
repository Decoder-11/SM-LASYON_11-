        "            else:\n",
        "                score += 5\n",
        "        max_score = len(self.data_pool) * 11\n",
        "        return (score / max_score) * 100 if max_score > 0 else 0\n",
        "\n",
        "    def autonomous_scan(self, constants_class):\n",
