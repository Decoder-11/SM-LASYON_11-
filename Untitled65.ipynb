        "            else \"OBSERVER LOCK\"\n",
        "            if year == 1911\n",
        "            else \"-\"\n",
        "        )\n",
        "        return {\n",
        "            \"NAME\": name,\n",
        "            \"10T\": f\"{day}.{month}.{year + 3}\",\n",
        "            \"SHIFT\": f\"{instant_shift:.4f}\",\n",
