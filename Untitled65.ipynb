        "        return {\"ISIM\": isim, \"10T\": f\"{gun}.{ay}.{yil+3}\", \"KAYMA\": f\"{anlik_kayma:.4f}\", \"11T\": f\"{s_gun}.{s_ay}.{s_yil}\", \"MEVSIM\": mevsim, \"KOD\": durum}\n",
