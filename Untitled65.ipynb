        "            print(f\"  {Colors.FAIL}USGS Veri Cekme Hatasi: {e}{Colors.RESET}\")\n",
        "        return []\n",
        "\n",
        "    def calculate_orbital_phases(self):\n",
        "        \"\"\"Ay, Merkur ve Mars yorunge fazlarini (0-360) simule et\"\"\"\n",
        "        now = datetime_class.now()\n",
